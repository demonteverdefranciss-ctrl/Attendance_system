# --- Backend API ---
API_BASE_URL=http://localhost/attendance_system/public/api/v1

# --- Device (camera) credentials ---
# Create a camera row in the backend; CAMERA_ID is its id, DEVICE_KEY the plaintext key.
CAMERA_ID=1
DEVICE_KEY=demo-device-key-12345

# --- Video source ---
# A webcam index (0, 1, ...) or a Tapo RTSP URL, e.g.:
#   rtsp://USER:PASS@192.168.1.50:554/stream1
VIDEO_SOURCE=0

# --- Recognition tuning ---
# LBPH returns a DISTANCE (lower = better match). Accept matches at or below this.
LBPH_THRESHOLD=70
# Require this many consecutive confident frames before recording attendance.
MIN_CONSEC_FRAMES=5
# After recording a student, ignore them for this many seconds (avoid duplicates).
COOLDOWN_SECONDS=300
# How many face samples to capture per student during enrollment.
SAMPLES_PER_STUDENT=20
# Show a preview window while recognizing (1 = yes, 0 = headless).
SHOW_WINDOW=1
